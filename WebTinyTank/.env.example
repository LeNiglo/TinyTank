# --- WebTinyTank (Nuxt) configuration ---
# Copy to `.env` for local dev. `.env` is gitignored. Server-only values
# (API_URL/API_AUTH) are exposed to Nitro via runtimeConfig, never to the browser.

# Base URL of the DataTinyTank master web API.
# Direct local access to the master = http://localhost:1337/web
# In production the master sits behind nginx which rewrites /api/web -> /web,
# so the deployed value is e.g. http://tinytank.dev/api/web
API_URL=http://localhost:1337/web

# HTTP Basic auth for the master API, in `user:password` form.
# Must match DataTinyTank's AUTH_USER:AUTH_PASSWORD.
API_AUTH=tinytank:change-me-please

# Sentry DSN — leave empty to disable error reporting (no-op without it)
SENTRY_DSN=

# Nitro listen port (dev server uses 3000 by default)
# PORT=3000
