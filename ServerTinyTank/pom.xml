<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.lefrantguillaume</groupId>
    <artifactId>ServerTinyTank</artifactId>
    <packaging>jar</packaging>
    <version>1.8</version>
    <url>http://tinytank.lefrantguillaume.com</url>


    <properties>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- Low-latency game networking (latest available; project is unmaintained) -->
        <dependency>
            <groupId>com.esotericsoftware</groupId>
            <artifactId>kryonet</artifactId>
            <version>2.22.0-RC1</version>
        </dependency>

        <!-- CLI argument parsing -->
        <dependency>
            <groupId>args4j</groupId>
            <artifactId>args4j</artifactId>
            <version>2.37</version>
        </dependency>

        <!-- JSON parsing of tanks.json / obstacles.json / maps (was transitive via jersey-json) -->
        <dependency>
            <groupId>org.codehaus.jettison</groupId>
            <artifactId>jettison</artifactId>
            <version>1.5.4</version>
        </dependency>

        <!-- POJO <-> JSON for the master-server REST DTOs (replaces jersey-json POJO mapping) -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.18.2</version>
        </dependency>

        <!-- NOTE: javafx.util.Pair (used as a plain data type in ~19 files) is vendored in
             src/main/java/javafx/util/Pair.java instead of pulling org.openjfx:javafx-base,
             whose per-platform classifier jars break cross-platform (Docker) builds.
             javafx.geometry.Rectangle2D was replaced by java.awt.geom.Rectangle2D. -->
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
            </plugin>
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <version>3.8.0</version>
                <configuration>
                    <descriptorRefs>
                        <descriptorRef>jar-with-dependencies</descriptorRef>
                    </descriptorRefs>
                    <archive>
                        <manifest>
                            <addClasspath>true</addClasspath>
                            <mainClass>com.lefrantguillaume.Main</mainClass>
                        </manifest>
                        <manifestEntries>
                            <!-- KryoNet bundles an old Kryo that reflects into the JDK;
                                 modern JDKs require these packages to be opened at runtime. -->
                            <Add-Opens>java.base/java.lang java.base/java.lang.reflect java.base/java.util java.base/java.io</Add-Opens>
                        </manifestEntries>
                    </archive>
                </configuration>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>


</project>
