# --- TinyTank Master Server configuration ---

# HTTP port the API listens on
PORT=1337

# MongoDB connection string (database name is taken from the path)
MONGO_URL=mongodb://localhost:27017/tiny-tank

# Base URL used in activation / download links inside emails
WEB_URL=http://localhost:3000

# Secret used to sign JWT access tokens — CHANGE THIS in production
JWT_SECRET=change-me-please

# HTTP Basic auth credentials guarding every API route
AUTH_USER=tinytank
AUTH_PASSWORD=change-me-please

# SMTP transport for registration emails (optional in dev)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
